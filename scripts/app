#!/usr/bin/env bash
set -e

# Resolve the absolute path to the project root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"

ACTION="${1:-dev}"

generate_main() {
	# Check if mods folder and main.go exist
	HAS_MODS=false
	if [ -d "app/mods" ] && [ -f "app/mods/main.go" ]; then
		HAS_MODS=true
	fi

	# Check if admin module folder exists
	HAS_ADMIN=false
	if [ "$HAS_MODS" = true ] && [ -d "app/mods/admin" ]; then
		HAS_ADMIN=true
	fi

	# Check if client module folder exists
	HAS_CLIENT=false
	if [ "$HAS_MODS" = true ] && [ -d "app/mods/client" ]; then
		HAS_CLIENT=true
	fi

	# Scan app/routes recursively for packages containing a Register function
	ROUTE_DIRS=()
	if [ -d "app/routes" ]; then
		for file in $(find app/routes -type f -name "main.go" | sort); do
			if grep -q "func Register" "$file"; then
				dir=$(dirname "$file")
				ROUTE_DIRS+=("$dir")
			fi
		done
	fi

	# Separate API/Action routes from Pages routes
	API_ROUTE_DIRS=()
	PAGES_ROUTE_DIRS=()
	HAS_PAGES=false
	for dir in "${ROUTE_DIRS[@]}"; do
		if [[ "$dir" == app/routes/pages* ]]; then
			PAGES_ROUTE_DIRS+=("$dir")
			HAS_PAGES=true
		else
			API_ROUTE_DIRS+=("$dir")
		fi
	done

	echo "Generating main.go..."

	# Start generating main.go
	cat << 'EOF' > main.go
package main

import (
	"context"
	"errors"
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

EOF

	if [ "$HAS_MODS" = true ] && [ "$HAS_PAGES" = false ]; then
		echo '	"mthan-go-starter/app/mods"' >> main.go
	fi

	if [ "$HAS_ADMIN" = true ]; then
		echo '	"mthan-go-starter/app/mods/admin"' >> main.go
	fi

	if [ "$HAS_CLIENT" = true ]; then
		echo '	"mthan-go-starter/app/mods/client"' >> main.go
	fi

	for dir in "${ROUTE_DIRS[@]}"; do
		alias=$(echo "$dir" | sed 's|^app/||' | tr '/' '_')
		echo "	$alias \"mthan-go-starter/$dir\"" >> main.go
	done

	cat << 'EOF' >> main.go
	"mthan-go-starter/app/services"
)

func main() {
	// 1. Load application configuration
	cfg, err := services.LoadConfig()
	if err != nil {
		fmt.Printf("Failed to load configuration: %v\n", err)
		os.Exit(1)
	}

	// 2. Initialize Logger Service
	logger := services.NewLoggerService(cfg.Env)
	logger.Info("Configuration loaded successfully")

	// 3. Initialize layers
	svc := services.NewProcessService()
	mux := http.NewServeMux()
	
	// Register individual route packages dynamically
EOF
	for dir in "${API_ROUTE_DIRS[@]}"; do
		alias=$(echo "$dir" | sed 's|^app/||' | tr '/' '_')
		echo "	$alias.Register(mux, svc, logger, cfg)" >> main.go
	done

	if [ "$HAS_ADMIN" = true ]; then
		cat << 'EOF' >> main.go
	if cfg.AdminActive && cfg.AdminPath != "" && cfg.AdminUser != "" && cfg.AdminPass != "" {
		admin.Register(mux, svc, logger, cfg)
	} else {
		logger.Info("Admin Panel is disabled (admin.active is false or missing credentials in config)")
	}
EOF
	else
		echo '	logger.Info("Admin Panel is not compiled in this build")' >> main.go
	fi

	if [ "$HAS_CLIENT" = true ]; then
		cat << 'EOF' >> main.go
	// Serve React client if enabled, otherwise register dynamic pages, templates, or fallback landing page
	if cfg.Client {
		client.Register(mux, svc, logger, cfg)
	} else {
EOF

		if [ "$HAS_PAGES" = true ]; then
			echo '		// Register dynamic SSR HTML Page routes' >> main.go
			for dir in "${PAGES_ROUTE_DIRS[@]}"; do
				alias=$(echo "$dir" | sed 's|^app/||' | tr '/' '_')
				echo "		$alias.Register(mux, svc, logger, cfg)" >> main.go
			done
		else
			cat << 'EOF' >> main.go
		// Check for templates/ folder fallback first
		if _, err := os.Stat("templates"); err == nil {
			logger.Info("Serving static HTML templates from templates/")
			fs := http.Dir("templates")
			fileServer := http.FileServer(fs)
			mux.Handle("/", fileServer)
		} else {
EOF

			if [ "$HAS_MODS" = true ]; then
				cat << 'EOF' >> main.go
			mods.Register(mux, svc, logger)
EOF
			else
				cat << 'EOF' >> main.go
			mux.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
				if r.URL.Path != "/" {
					http.NotFound(w, r)
					return
				}
				w.Header().Set("Content-Type", "text/html; charset=utf-8")
				w.Write([]byte("<h1>Welcome to Mthan Go Starter Kit</h1><p>No modules are compiled. Serving API endpoints from routes instead.</p>"))
			})
EOF
			fi

			cat << 'EOF' >> main.go
		}
EOF
		fi

		cat << 'EOF' >> main.go
	}
EOF
	else
		cat << 'EOF' >> main.go
	if cfg.Client {
		logger.Warn("React client serving is enabled in config.yaml, but the client module is not compiled in this build")
	}
EOF

		if [ "$HAS_PAGES" = true ]; then
			echo '	// Register dynamic SSR HTML Page routes' >> main.go
			for dir in "${PAGES_ROUTE_DIRS[@]}"; do
				alias=$(echo "$dir" | sed 's|^app/||' | tr '/' '_')
				echo "	$alias.Register(mux, svc, logger, cfg)" >> main.go
			done
		else
			cat << 'EOF' >> main.go
	// Check for templates/ folder fallback first
	if _, err := os.Stat("templates"); err == nil {
		logger.Info("Serving static HTML templates from templates/")
		fs := http.Dir("templates")
		fileServer := http.FileServer(fs)
		mux.Handle("/", fileServer)
	} else {
EOF

			if [ "$HAS_MODS" = true ]; then
				cat << 'EOF' >> main.go
		mods.Register(mux, svc, logger)
EOF
			else
				cat << 'EOF' >> main.go
		mux.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
			if r.URL.Path != "/" {
				http.NotFound(w, r)
				return
			}
			w.Header().Set("Content-Type", "text/html; charset=utf-8")
			w.Write([]byte("<h1>Welcome to Mthan Go Starter Kit</h1><p>No modules are compiled. Serving API endpoints from routes instead.</p>"))
		})
EOF
			fi

			cat << 'EOF' >> main.go
	}
EOF
		fi
	fi

	cat << 'EOF' >> main.go

	// 4. Setup HTTP Server
	server := &http.Server{
		Addr:         ":" + cfg.Port,
		Handler:      mux,
		ReadTimeout:  10 * time.Second,
		WriteTimeout: 10 * time.Second,
		IdleTimeout:  120 * time.Second,
	}

	// 5. Handle Graceful Shutdown
	serverCtx, serverStopCtx := context.WithCancel(context.Background())

	sigChan := make(chan os.Signal, 1)
	signal.Notify(sigChan, syscall.SIGHUP, syscall.SIGINT, syscall.SIGTERM, syscall.SIGQUIT)
	
	go func() {
		<-sigChan
		logger.Info("Shutting down server gracefully...")

		// Shutdown context with a 10 second timeout limit
		shutdownCtx, shutdownCancel := context.WithTimeout(serverCtx, 10*time.Second)
		defer shutdownCancel()

		go func() {
			<-shutdownCtx.Done()
			if shutdownCtx.Err() == context.DeadlineExceeded {
				logger.Error("Graceful shutdown timed out. Forcing exit.")
				os.Exit(1)
			}
		}()

		// Trigger shutdown
		if err := server.Shutdown(shutdownCtx); err != nil {
			logger.Error("HTTP server Shutdown failed", "error", err)
			os.Exit(1)
		}
		serverStopCtx()
	}()

	// 6. Start HTTP Server
	logger.Info("Server is running", "addr", server.Addr, "mode", cfg.Env)
	if err := server.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {
		logger.Error("ListenAndServe failed to start", "error", err)
		os.Exit(1)
	}

	// Wait for shutdown goroutine to finish cleaning up
	<-serverCtx.Done()
	logger.Info("Server stopped cleanly")
}
EOF

	echo "main.go generated successfully."
}

case "$ACTION" in
	dev)
		echo "Starting application in development mode..."
		
		APP_DIR="app/mods/client"

		# Warning message if client dependencies need to be installed
		if [ -d "$APP_DIR" ] && [ ! -d "$APP_DIR/node_modules" ]; then
			echo "------------------------------------------------------------------------"
			echo "WARNING: $APP_DIR/node_modules is missing."
			echo "Please run './scripts/client dev-app' or npm install inside the client directory."
			echo "------------------------------------------------------------------------"
		fi

		# 1. Start Go server
		generate_main
		go run main.go "${@:2}" &
		GO_PID=$!

		# 2. Start React Vite server (if node_modules exists)
		CLIENT_PID=""
		if [ -d "$APP_DIR" ] && [ -d "$APP_DIR/node_modules" ]; then
			echo "Starting React client dev server on port 3000..."
			npm run dev --prefix "$APP_DIR" &
			CLIENT_PID=$!
		fi

		# Clean process termination handler
		cleanup() {
			echo ""
			echo "Stopping development servers..."
			if [ -n "$GO_PID" ]; then
				kill "$GO_PID" 2>/dev/null || true
			fi
			if [ -n "$CLIENT_PID" ]; then
				kill "$CLIENT_PID" 2>/dev/null || true
			fi
			exit 0
		}

		trap cleanup SIGINT SIGTERM EXIT
		wait
		;;
	run)
		if [ ! -f "build/mthan-app" ]; then
			echo "Error: Binary 'build/mthan-app' not found. Please compile the app first with: ./scripts/app build"
			exit 1
		fi
		echo "Running compiled application..."
		exec ./build/mthan-app "${@:2}"
		;;
	test)
		echo "Running Go tests..."
		go test -v ./...
		;;
	build)
		# Create the build destination folder
		mkdir -p build

		# Dynamically generate main.go based on active modules
		generate_main

		echo "Compiling application..."
		go build -o build/mthan-app main.go

		echo "Compilation successful. Binary located at: build/mthan-app"
		;;
	*)
		echo "Usage: $0 {dev|run|test|build}"
		exit 1
		;;
esac

#!/usr/bin/env bash
set -e

# Resolve the absolute path to the project root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"

# Extract admin path prefix from config/config.yaml
ADMIN_PATH=""
if [ -f "config/config.yaml" ]; then
	# Extract from admin section, path line
	ADMIN_PATH=$(grep -A 10 "admin:" config/config.yaml | grep "path:" | head -n 1 | cut -d ':' -f2 | tr -d ' "' | tr -d "'" || true)
fi
# Default to /admin if not found or empty
if [ -z "$ADMIN_PATH" ]; then
	ADMIN_PATH="/admin"
fi
# Ensure it starts with /
if [[ ! "$ADMIN_PATH" =~ ^/ ]]; then
	ADMIN_PATH="/$ADMIN_PATH"
fi
# Ensure it ends with / for Vite base path
VITE_BASE="$ADMIN_PATH"
if [[ ! "$VITE_BASE" =~ /$ ]]; then
	VITE_BASE="$VITE_BASE/"
fi
export VITE_ADMIN_PATH="$ADMIN_PATH"
export VITE_BASE="$VITE_BASE"

ACTION="${1:-build-app}"

case "$ACTION" in
	build-app)
		APP_DIR="app/mods/client"
		if [ ! -d "$APP_DIR" ]; then
			echo "Error: '$APP_DIR' directory not found."
			exit 1
		fi
		# Auto-install dependencies if node_modules is missing
		if [ ! -d "$APP_DIR/node_modules" ]; then
			echo "Installing public client dependencies..."
			npm install --prefix "$APP_DIR"
		fi
		echo "Building React public client..."
		npm run build --prefix "$APP_DIR"
		echo "React public client built successfully. Static files are located in: $APP_DIR/build"
		;;
	build-admin)
		ADMIN_DIR="app/mods/admin"
		if [ ! -d "$ADMIN_DIR" ]; then
			echo "Error: Admin client directory '$ADMIN_DIR' not found."
			exit 1
		fi
		# Auto-install dependencies if node_modules is missing
		if [ ! -d "$ADMIN_DIR/node_modules" ]; then
			echo "Installing admin client dependencies..."
			npm install --prefix "$ADMIN_DIR"
		fi
		echo "Building React admin client..."
		npm run build --prefix "$ADMIN_DIR"
		echo "React admin client built successfully. Static files are located in: $ADMIN_DIR/build"
		;;
	dev-app)
		APP_DIR="app/mods/client"
		if [ ! -d "$APP_DIR" ]; then
			echo "Error: '$APP_DIR' directory not found."
			exit 1
		fi
		if [ ! -d "$APP_DIR/node_modules" ]; then
			npm install --prefix "$APP_DIR"
		fi
		echo "Running public client dev server..."
		npm run dev --prefix "$APP_DIR"
		;;
	dev-admin)
		ADMIN_DIR="app/mods/admin"
		if [ ! -d "$ADMIN_DIR" ]; then
			echo "Error: Admin client directory '$ADMIN_DIR' not found."
			exit 1
		fi
		if [ ! -d "$ADMIN_DIR/node_modules" ]; then
			npm install --prefix "$ADMIN_DIR"
		fi
		echo "Running admin client dev server..."
		npm run dev --prefix "$ADMIN_DIR"
		;;
	*)
		echo "Usage: $0 {build-app|build-admin|dev-app|dev-admin}"
		exit 1
		;;
esac
